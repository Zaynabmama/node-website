<!DOCTYPE html>
<html lang="en">
<head>
  <% include partials/head %>
</head>
<body>
  <% include partials/menu %>

  <section class="container section-space">
    <h2 class="section-title"><%= page %></h2>
    <p class="lead">Create an account and choose whether you want to shop as a client or manage the store as an admin.</p>

    <div class="row">
      <div class="col-sm-6">
        <div class="auth-card">
          <div class="auth-switch">
            <button type="button" class="btn btn-default auth-toggle active" data-mode="signin">Sign in</button>
            <button type="button" class="btn btn-default auth-toggle" data-mode="signup">Create account</button>
          </div>

          <form id="auth-form">
            <input id="auth-name" type="text" placeholder="Full name" required>
            <input id="auth-email" type="email" placeholder="Email address" required>
            <input id="auth-password" type="password" placeholder="Password" required>
            <select id="auth-role">
              <option value="client">Client</option>
              <option value="admin">Admin</option>
            </select>
            <button class="btn btn-primary" type="submit">Continue</button>
          </form>

          <div id="otp-section" class="hidden">
            <input id="otp-code" type="text" placeholder="Enter OTP code">
            <button id="otp-submit" class="btn btn-primary" type="button">Verify OTP</button>
          </div>
          <div id="auth-status" class="auth-status"></div>
          <div id="signout-area" class="hidden" style="margin-top: 12px;">
            <button id="signout-button" class="btn btn-default" type="button">Sign out</button>
          </div>
        </div>
      </div>

      <div class="col-sm-6">
        <div class="auth-card">
          <h4>What you can do</h4>
          <ul>
            <li>Clients can browse products and place orders.</li>
            <li>Admins can manage the shop and oversee inventory.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

</body>
<% include partials/script %>
</html>
