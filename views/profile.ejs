<!DOCTYPE html>
<html lang="en">
<head>
  <% include partials/head %>
</head>
<body>
  <% include partials/menu %>

  <section class="container section-space">
    <h2 class="section-title"><%= page %></h2>
    <p class="lead">Review your cart and update your personal information.</p>

    <div class="row">
      <div class="col-sm-6">
        <div class="profile-card">
          <h3>Your information</h3>
          <div id="profile-signin-prompt" class="profile-signin-prompt" style="display:none; padding: 24px; border: 1px solid #ddd; border-radius: 6px; background: #fafafa; text-align: center;">
            <p style="font-size: 16px; margin-bottom: 16px;">You are not signed in yet.</p>
            <p style="margin-bottom: 20px;">Please sign in to view and update your profile information and order history.</p>
            <a class="btn btn-primary" href="/auth">Sign in</a>
          </div>
          <form id="profile-form">
            <input id="profile-name" type="text" placeholder="Full name">
            <input id="profile-email" type="email" placeholder="Email address">
            <input id="profile-phone" type="text" placeholder="Phone number">
            <input id="profile-address" type="text" placeholder="Shipping address">
            <button class="btn btn-primary" type="submit">Save changes</button>
          </form>
          <div id="profile-status" class="auth-status"></div>
          <button id="profile-signout" class="btn btn-default" type="button" style="margin-top: 12px;">Sign out</button>
        </div>
      </div>

      <div class="col-sm-6">
        <div id="profile-cart-card" class="profile-card">
          <h3>Your cart</h3>
          <div id="profile-cart-summary" class="profile-summary"></div>
          <div id="profile-cart-items"></div>
        </div>
        <div id="profile-orders-card" class="profile-card" style="margin-top: 20px;">
          <h3>Your orders</h3>
          <div id="profile-orders"></div>
        </div>
        <div id="admin-dashboard" class="profile-card" style="display:none; margin-top: 20px;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
            <h3 style="margin:0;">Admin dashboard</h3>
            <button id="admin-add-product" class="btn btn-primary" type="button">Add product</button>
          </div>
          <div id="admin-products"></div>
          <div id="admin-reviews" style="margin-top: 20px;"></div>
        </div>

        <div id="admin-add-product-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:1000; align-items:center; justify-content:center;">
          <div style="background:#fff; max-width:520px; width:100%; padding:24px; border-radius:8px; box-shadow:0 12px 24px rgba(0,0,0,.15); position:relative;">
            <button id="admin-add-product-close" type="button" style="position:absolute; top:16px; right:16px; border:none; background:none; font-size:18px; cursor:pointer;">×</button>
            <h4 style="margin-top:0;">Add new product</h4>
            <form id="admin-add-product-form">
              <div style="margin-bottom:12px;"><label>Name<br><input name="name" type="text" required style="width:100%; padding:8px;" /></label></div>
              <div style="margin-bottom:12px;"><label>Brand<br><input name="brand" type="text" required style="width:100%; padding:8px;" /></label></div>
              <div style="margin-bottom:12px;"><label>Price<br><input name="price" type="text" required placeholder="$24.00" style="width:100%; padding:8px;" /></label></div>
              <div style="margin-bottom:12px;"><label>Badge<br><input name="badge" type="text" placeholder="Bestseller" style="width:100%; padding:8px;" /></label></div>
              <div style="margin-bottom:12px;"><label>Emoji<br><input name="emoji" type="text" placeholder="💄" style="width:100%; padding:8px;" /></label></div>
              <div style="margin-bottom:12px;"><label>Description<br><textarea name="description" required rows="3" style="width:100%; padding:8px;"></textarea></label></div>
              <div style="margin-bottom:12px; display:flex; gap:16px; align-items:center;"><label>Stock<br><input name="stock" type="number" min="0" value="0" style="width:120px; padding:8px;" /></label><label><input name="soldOut" type="checkbox" /> Sold out</label></div>
              <div style="margin-bottom:12px;"><label>Image URL 1<br><input name="image1" type="text" placeholder="https://..." style="width:100%; padding:8px;" /></label></div>
              <div style="margin-bottom:12px;"><label>Image URL 2<br><input name="image2" type="text" placeholder="https://..." style="width:100%; padding:8px;" /></label></div>
              <div style="margin-bottom:12px;"><label>Image URL 3<br><input name="image3" type="text" placeholder="https://..." style="width:100%; padding:8px;" /></label></div>
              <div style="margin-bottom:12px;"><label>Model image URL<br><input name="modelImage" type="text" placeholder="https://..." style="width:100%; padding:8px;" /></label></div>
              <div style="text-align:right; margin-top:16px;"><button class="btn btn-default" type="button" id="admin-add-product-cancel" style="margin-right:8px;">Cancel</button><button class="btn btn-primary" type="submit">Add product</button></div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

</body>
<% include partials/script %>
</html>
