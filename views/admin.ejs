<!DOCTYPE html>
<html lang="en">
<head>
  <% include partials/head %>
</head>
<body>
  <% include partials/menu %>

  <section class="container section-space">
    <h2 class="section-title"><%= page %></h2>
    <p class="lead">Manage product availability and stock levels.</p>

    <div class="profile-card">
      <% products.forEach(function(product) { %>
        <div class="profile-cart-item">
          <h4><%= product.name %></h4>
          <p><strong>Brand:</strong> <%= product.brand %></p>
          <p><strong>Stock:</strong> <%= product.stock %></p>
          <p><strong>Status:</strong> <%= product.soldOut ? 'Sold out' : 'Available' %></p>
          <form class="admin-stock-form" data-id="<%= product.id %>">
            <input type="number" min="0" value="<%= product.stock %>" name="stock" placeholder="Stock available">
            <label>
              <input type="checkbox" name="soldOut" <%= product.soldOut ? 'checked' : '' %>> Mark as sold out
            </label>
            <button class="btn btn-primary" type="submit">Save</button>
          </form>
        </div>
      <% }); %>
    </div>
  </section>

</body>
<% include partials/script %>
</html>
